{
  "version": 2,
  "cleanUrls": true,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.css",
      "use": "@vercel/static"
    },
    {
      "src": "*.js",
      "use": "@vercel/static"
    },
    {
      "src": "data/*.js",
      "use": "@vercel/static"
    },
    {
      "src": "*.png",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/env.js",
      "dest": "/api/env.js"
    },
    {
      "src": "/live(/.*)?",
      "dest": "/"
    },
    {
      "src": "/loyalty(/.*)?",
      "dest": "/"
    },
    {
      "src": "/content(/.*)?",
      "dest": "/"
    },
    {
      "src": "/pass(/.*)?",
      "dest": "/"
    },
    {
      "src": "/admin(/.*)?",
      "dest": "/"
    },
    {
      "src": "/home",
      "dest": "/"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}