{
  "version": 2,
  "cleanUrls": true,
  "builds": [
    { "src": "api/waitlist.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "index.css",  "use": "@vercel/static" },
    { "src": "index.js",   "use": "@vercel/static" },
    { "src": "logo.png",   "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/waitlist", "dest": "/api/waitlist.js" },
    { "src": "/index.css",   "dest": "/index.css" },
    { "src": "/index.js",    "dest": "/index.js" },
    { "src": "/logo.png",    "dest": "/logo.png" },
    { "src": "/(.*)",        "dest": "/index.html" }
  ]
}
